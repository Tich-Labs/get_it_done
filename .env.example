# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Pesapal Configuration
NEXT_PUBLIC_PESAPAL_CLIENT_ID=your_pesapal_client_id
PESAPAL_API_KEY=your_pesapal_api_key
PESAPAL_SECRET_KEY=your_pesapal_secret_key
PESAPAL_CALLBACK_URL=http://localhost:3000/api/webhooks/pesapal

# SendGrid (for email)
SENDGRID_API_KEY=your_sendgrid_api_key

# Twilio (for SMS/WhatsApp - optional)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+254...

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
